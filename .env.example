# ============================================================
# ScANN — LLM / AI 分析配置模板
# 复制此文件为 .env 并填入你的实际配置。
#   cp .env.example .env
# ============================================================

# Chat Completions 接口地址
SCANN_LLM_API_URL=在此填入你的接口地址

# API Key（必填，否则 AI 分析不可用）
SCANN_LLM_API_KEY=在此填入你的API密钥

# 模型名称（可选，默认 Qwen/Qwen3-8B）
SCANN_LLM_MODEL=Qwen/Qwen3-8B

# 是否默认开启 Qwen3 思考模式（true / false）
SCANN_LLM_ENABLE_THINKING=false

# 请求超时时间（秒）
SCANN_LLM_TIMEOUT_SECONDS=90

# 最大生成 Token 数
SCANN_LLM_MAX_TOKENS=600

# 生成温度（0-1，越低越确定）
SCANN_LLM_TEMPERATURE=0.2
